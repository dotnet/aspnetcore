<?xml version="1.0" encoding="utf-8"?>
<!-- Traversal ceiling: clears every inherited section so repo-root package
     sources never merge into content placed directly under .worktrees/. -->
<configuration>
  <config>
    <clear />
  </config>
  <packageSources>
    <clear />
  </packageSources>
  <packageSourceMapping>
    <clear />
  </packageSourceMapping>
</configuration>
