<Project>
  <PropertyGroup>
    <_BlazorGatewayDll Condition="'$(_BlazorGatewayDll)' == ''">$(MSBuildThisFileDirectory)../tools/blazor-gateway.dll</_BlazorGatewayDll>
    <!-- Prevents the runtime SDK (Microsoft.NET.Sdk.WebAssembly.Browser.targets) from overriding
         RunCommand/RunArguments with WasmAppHost when _UseBlazorDevServer is false. -->
    <_WebAssemblyUserRunParameters>true</_WebAssemblyUserRunParameters>
    <!-- Set RunCommand/RunArguments as static properties so they are visible to VS (F5/Ctrl+F5)
         which reads properties directly without running the ComputeRunArguments target. -->
    <_GatewayStaticWebAssetsManifest>$([System.IO.Path]::Combine('$(MSBuildProjectDirectory)', '$(IntermediateOutputPath)', 'staticwebassets.development.json'))</_GatewayStaticWebAssetsManifest>
    <_GatewayEndpointsManifest>$([System.IO.Path]::Combine('$(MSBuildProjectDirectory)', '$(IntermediateOutputPath)', 'staticwebassets.build.endpoints.json'))</_GatewayEndpointsManifest>
    <RunCommand>dotnet</RunCommand>
    <RunArguments>&quot;$(_BlazorGatewayDll)&quot; --environment Development --staticWebAssets &quot;$(_GatewayStaticWebAssetsManifest)&quot; --ClientApps:app:EndpointsManifest &quot;$(_GatewayEndpointsManifest)&quot; --ClientApps:app:PathPrefix &quot;&quot;</RunArguments>
  </PropertyGroup>
</Project>
