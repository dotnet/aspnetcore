<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
    <IsAnalyzersProject>true</IsAnalyzersProject>
    <AddPublicApiAnalyzers>false</AddPublicApiAnalyzers>
    <Nullable>enable</Nullable>
    <WarnOnNullable>true</WarnOnNullable>
    <IsPackable>false</IsPackable>
    <!-- Suppress RS2008: analyzer release tracking. Not needed — our analyzer ships as part of the library, not standalone. -->
    <NoWarn>$(NoWarn);RS2008</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Microsoft.AspNetCore.Components.Testing.Tests" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="Microsoft.CodeAnalysis.CSharp" PrivateAssets="all" />
  </ItemGroup>

</Project>
