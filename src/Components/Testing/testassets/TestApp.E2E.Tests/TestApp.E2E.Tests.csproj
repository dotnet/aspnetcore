<Project Sdk="Microsoft.NET.Sdk">

  <Import Project="../../eng/targets/Microsoft.AspNetCore.Components.Testing.props" />

  <PropertyGroup>
    <TargetFramework>$(DefaultNetCoreTargetFramework)</TargetFramework>
    <OutputType>Exe</OutputType>
    <IsPackable>false</IsPackable>
    <!-- MSTest.TestFramework injects MSTest.TestFramework.Extensions Reference via buildTransitive .targets;
         opt out of the aspnetcore custom-reference restriction so it isn't rejected. -->
    <DisablePackageReferenceRestrictions>true</DisablePackageReferenceRestrictions>
    <!-- NETSDK1023: SDK warns about explicit MSTest.TestAdapter PackageReference; we want the
         explicit one so the version is pinned to MSTest.TestFramework. -->
    <!-- MSTEST0001: Parallelism analyzer requires opt-in/opt-out at assembly level; opt out
         until we have a strategy (default is method-level parallelism, which is fine here). -->
    <NoWarn>$(NoWarn);NETSDK1023;MSTEST0001</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="MSTest.TestFramework" />
    <Reference Include="Microsoft.Testing.Platform.MSBuild" />
    <Reference Include="Microsoft.Playwright" />
    <Reference Include="Microsoft.Testing.Extensions.Retry" />
  </ItemGroup>

  <!-- MSTest.TestAdapter is implicitly referenced by the SDK for test projects.
       We list it as an explicit PackageReference (not Reference, to avoid the aspnetcore
       custom resolver replacing it) so the version is pinned to match MSTest.TestFramework. -->
  <ItemGroup>
    <PackageReference Include="MSTest.TestAdapter" Version="$(MSTestVersion)" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="Microsoft.AspNetCore.Components.Testing" />
    <ProjectReference Include="../TestApp/TestApp.csproj">
      <E2EApp>true</E2EApp>
    </ProjectReference>
  </ItemGroup>

  <Import Project="../../eng/targets/Microsoft.AspNetCore.Components.Testing.targets" />

</Project>
