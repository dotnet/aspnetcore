<Project>
  <Import Project="$([MSBuild]::GetPathOfFileAbove('Directory.Build.props', '$(MSBuildThisFileDirectory)../'))" />

  <!-- E2E test projects use xUnit v3; disable the Arcade SDK's auto-included xUnit v2 -->
  <PropertyGroup Condition=" $(IsTestProject) ">
    <UsingToolXUnit>false</UsingToolXUnit>
    <GenerateLoggingTestingAssemblyAttributes>false</GenerateLoggingTestingAssemblyAttributes>
    <!-- NU1903: Transitive Newtonsoft.Json vulnerability from nuget.org packages -->
    <NoWarn>$(NoWarn);NU1903</NoWarn>
  </PropertyGroup>

  <!-- Remove auto-added xUnit v2 test infra from CSharp.Common.props -->
  <ItemGroup Condition=" $(IsTestProject) ">
    <Reference Remove="Microsoft.AspNetCore.InternalTesting" />
    <Reference Remove="Moq" />
    <Compile Remove="$(SharedSourceRoot)test\SuccessfulTests.cs" />
  </ItemGroup>

  <!--
    E2E test projects host a YARP proxy in-process (WebApplication.CreateSlimBuilder) which
    requires the full ASP.NET Core shared framework at runtime. In the aspnetcore repo,
    transitive References from shipping libraries don't copy to the test output, so test
    projects use the bulk @(AspNetCoreAppReference) items from SharedFramework.Local.props.
  -->
  <ItemGroup Condition=" $(IsTestProject) ">
    <Reference Include="@(AspNetCoreAppReference)" />
    <Reference Include="@(AspNetCoreAppReferenceAndPackage)" />
  </ItemGroup>
</Project>
