@model MvcDemo.Models.RegistrationModel

@{
    ViewData["Title"] = "Registration";
}

<div class="container">
    <span class="app-badge">ASP.NET MVC</span>
    <h1>Registration Form</h1>
    <p class="subtitle">Client-side validation powered by <code>aspnet-core-validation.js</code> — no jQuery needed.</p>

    @if (ViewData["Success"] is true)
    {
        <div class="success-message">✅ Registration submitted successfully (server-side validation passed).</div>
    }

    <form asp-action="Index" method="post" id="registration-form">
        <fieldset id="registration-fieldset">
        <div asp-validation-summary="ModelOnly"></div>

        <div class="form-group">
            <label asp-for="Name"></label>
            <input asp-for="Name" />
            <span asp-validation-for="Name"></span>
        </div>

        <div class="form-group">
            <label asp-for="Email"></label>
            <div class="field-wrapper">
                <input asp-for="Email" placeholder="Try admin@example.com" />
                <div class="pending-indicator">
                    <span class="spinner"></span>
                    Checking&hellip;
                </div>
            </div>
            <span asp-validation-for="Email"></span>
        </div>

        <div class="form-group">
            <label asp-for="Username"></label>
            <div class="field-wrapper">
                <input asp-for="Username" placeholder="Try admin, root, test" />
                <div class="pending-indicator">
                    <span class="spinner"></span>
                    Checking&hellip;
                </div>
            </div>
            <span asp-validation-for="Username"></span>
        </div>

        <div class="form-group">
            <label asp-for="Phone"></label>
            <input asp-for="Phone" />
            <span asp-validation-for="Phone"></span>
        </div>

        <div class="form-group">
            <label asp-for="Website"></label>
            <input asp-for="Website" />
            <span asp-validation-for="Website"></span>
        </div>

        <div class="form-group">
            <label asp-for="Password"></label>
            <input asp-for="Password" />
            <span asp-validation-for="Password"></span>
        </div>

        <div class="form-group">
            <label asp-for="ConfirmPassword"></label>
            <input asp-for="ConfirmPassword" />
            <span asp-validation-for="ConfirmPassword"></span>
        </div>

        <div class="form-group">
            <label asp-for="Age"></label>
            <input asp-for="Age" />
            <span asp-validation-for="Age"></span>
        </div>

        <div class="form-group">
            <label asp-for="CreditCard"></label>
            <input asp-for="CreditCard" />
            <span asp-validation-for="CreditCard"></span>
        </div>

        <div class="form-group">
            <label asp-for="ZipCode"></label>
            <input asp-for="ZipCode" />
            <span asp-validation-for="ZipCode"></span>
        </div>

        <div class="form-group">
            <label asp-for="AvatarFilename"></label>
            <input asp-for="AvatarFilename" placeholder="e.g. photo.png" />
            <span asp-validation-for="AvatarFilename"></span>
        </div>

        <div class="button-group">
            <button type="submit" class="btn-submit" id="submit-btn">Register</button>
            <button type="reset" class="btn-reset">Reset</button>
        </div>
        <div class="button-group">
            <button type="submit" formnovalidate class="btn-novalidate">Submit without validation</button>
        </div>
        </fieldset>
    </form>
</div>

@section Scripts {
    <script src="~/lib/aspnet-core-validation/aspnet-core-validation.js"></script>
    <script>
        (function () {
            var form = document.getElementById('registration-form');
            var fieldset = document.getElementById('registration-fieldset');
            var btn = document.getElementById('submit-btn');

            form.addEventListener('submit', function () {
                fieldset.disabled = true;
                btn.textContent = 'Validating\u2026';
            });

            form.addEventListener('validationcomplete', function () {
                fieldset.disabled = false;
                btn.textContent = 'Register';
            });
        })();
    </script>
}
