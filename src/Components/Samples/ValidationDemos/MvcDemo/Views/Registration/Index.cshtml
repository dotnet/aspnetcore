@model MvcDemo.Models.RegistrationModel

@{
    ViewData["Title"] = "Registration";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <h1 class="h3 mb-1">Registration Form</h1>
            <p class="text-body-secondary mb-4">Client-side validation powered by <code>aspnet-core-validation.js</code> — no jQuery needed.</p>

            @if (ViewData["Success"] is true)
            {
                <div class="success-message">✅ Registration submitted successfully (server-side validation passed).</div>
            }

            <form asp-action="Index" method="post" id="registration-form">
                <fieldset id="registration-fieldset">
                <div asp-validation-summary="ModelOnly"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <div class="position-relative">
                        <input asp-for="Email" class="form-control" placeholder="Try admin@example.com" />
                        <div class="pending-indicator">
                            <span class="spinner-border spinner-border-sm" role="status"></span>
                            Checking&hellip;
                        </div>
                    </div>
                    <span asp-validation-for="Email"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Username" class="form-label"></label>
                    <div class="position-relative">
                        <input asp-for="Username" class="form-control" placeholder="Try admin, root, test" />
                        <div class="pending-indicator">
                            <span class="spinner-border spinner-border-sm" role="status"></span>
                            Checking&hellip;
                        </div>
                    </div>
                    <span asp-validation-for="Username"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Phone" class="form-label"></label>
                    <input asp-for="Phone" class="form-control" />
                    <span asp-validation-for="Phone"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Website" class="form-label"></label>
                    <input asp-for="Website" class="form-control" />
                    <span asp-validation-for="Website"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" />
                    <span asp-validation-for="Password"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ConfirmPassword" class="form-label"></label>
                    <input asp-for="ConfirmPassword" class="form-control" />
                    <span asp-validation-for="ConfirmPassword"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Age" class="form-label"></label>
                    <input asp-for="Age" class="form-control" />
                    <span asp-validation-for="Age"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="CreditCard" class="form-label"></label>
                    <input asp-for="CreditCard" class="form-control" />
                    <span asp-validation-for="CreditCard"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ZipCode" class="form-label"></label>
                    <input asp-for="ZipCode" class="form-control" />
                    <span asp-validation-for="ZipCode"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="AvatarFilename" class="form-label"></label>
                    <input asp-for="AvatarFilename" class="form-control" placeholder="e.g. photo.png" />
                    <span asp-validation-for="AvatarFilename"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-warning" id="submit-btn">Register</button>
                    <button type="reset" class="btn btn-outline-secondary">Reset</button>
                </div>
                <div class="mt-2">
                    <button type="submit" formnovalidate class="btn btn-outline-secondary btn-sm">Submit without validation</button>
                </div>
                </fieldset>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/aspnet-core-validation/aspnet-core-validation.js"></script>
    <script>
        (function () {
            var form = document.getElementById('registration-form');
            var fieldset = document.getElementById('registration-fieldset');
            var btn = document.getElementById('submit-btn');

            form.addEventListener('submit', function () {
                fieldset.disabled = true;
                btn.textContent = 'Validating\u2026';
            });

            form.addEventListener('validationcomplete', function () {
                fieldset.disabled = false;
                btn.textContent = 'Register';
            });
        })();
    </script>
}
