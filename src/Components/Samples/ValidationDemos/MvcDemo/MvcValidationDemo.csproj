<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net11.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- Use standard NuGet feeds, not the repository's custom NuGet.config -->
    <RestoreConfigFile>$(MSBuildThisFileDirectory)NuGet.config</RestoreConfigFile>
  </PropertyGroup>

  <!-- Copy the validation JS bundle from the Web.JS build output -->
  <PropertyGroup>
    <ValidationJsSource>$([MSBuild]::NormalizePath('$(MSBuildThisFileDirectory)..\..\..\Web.JS\dist\Debug\aspnet-core-validation.js'))</ValidationJsSource>
    <ValidationJsTarget>$(MSBuildThisFileDirectory)wwwroot\lib\aspnet-core-validation\aspnet-core-validation.js</ValidationJsTarget>
  </PropertyGroup>

  <Target Name="CopyValidationJs" BeforeTargets="Build">
    <Error Condition="!Exists('$(ValidationJsSource)')" Text="Validation JS not found at $(ValidationJsSource). Run 'npm run build' in src/Components/Web.JS first." />
    <MakeDir Directories="$(MSBuildThisFileDirectory)wwwroot\lib\aspnet-core-validation" />
    <Copy SourceFiles="$(ValidationJsSource)" DestinationFiles="$(ValidationJsTarget)" SkipUnchangedFiles="true" />
    <Message Importance="high" Text="Copied aspnet-core-validation.js to wwwroot" />
  </Target>

</Project>
