@page "/"
@using System.Globalization
@using Microsoft.Extensions.Localization
@using BlazorSSRNet11.Models

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-8">
            <h3>@Loc["PageTitle"]</h3>
            <p class="text-body-secondary mb-4">@Loc["PageSubtitle"]</p>

            <div class="mb-3 d-flex gap-2 small">
                🌐
                <a href="/Culture/Set?culture=en&redirectUri=/" class="@(CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "en" ? "fw-bold" : "")">English</a>
                <a href="/Culture/Set?culture=es&redirectUri=/" class="@(CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "es" ? "fw-bold" : "")">Español</a>
            </div>

            <EditForm Model="Model" Enhance FormName="registration" OnValidSubmit="HandleValidSubmit" id="registration-form">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label for="Name" class="form-label">@Loc["FullName"]</label>
                    <InputText @bind-Value="Model.Name" id="Name" class="form-control" autocomplete="off" />
                    <ValidationMessage For="@(() => Model.Name)" />
                </div>

                <div class="mb-3">
                    <label for="Email" class="form-label">@Loc["Email"]</label>
                    <InputText @bind-Value="Model.Email" id="Email" class="form-control" autocomplete="off" />
                    <ValidationMessage For="@(() => Model.Email)" />
                </div>

                <div class="mb-3">
                    <label for="Password" class="form-label">@Loc["Password"]</label>
                    <InputText @bind-Value="Model.Password" id="Password" type="password" class="form-control" autocomplete="new-password" />
                    <ValidationMessage For="@(() => Model.Password)" />
                </div>

                <div class="mb-3">
                    <label for="ConfirmPassword" class="form-label">@Loc["ConfirmPassword"]</label>
                    <InputText @bind-Value="Model.ConfirmPassword" id="ConfirmPassword" type="password" class="form-control" autocomplete="new-password" />
                    <ValidationMessage For="@(() => Model.ConfirmPassword)" />
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-info" id="submit-btn">@Loc["Register"]</button>
                    <button type="reset" class="btn btn-outline-secondary">@Loc["Reset"]</button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    [Inject] private IStringLocalizer<BlazorSSRNet11.Resources.LocalizedStrings> Loc { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    [SupplyParameterFromForm]
    private RegistrationModel Model { get; set; } = new();

    private void HandleValidSubmit()
    {
        Nav.NavigateTo("/success");
    }
}
