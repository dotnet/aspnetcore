@page "/success"
@using Microsoft.Extensions.Localization
@using BlazorSSRNet11.Resources

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-8 text-center">
            <h3 class="text-success">✅ @Loc["SuccessTitle"]</h3>
            <p class="text-body-secondary mb-4">@Loc["SuccessMessage"]</p>
            <a href="/" class="btn btn-outline-primary">@Loc["BackToForm"]</a>
        </div>
    </div>
</div>

@code {
    [Inject] private IStringLocalizer<LocalizedStrings> Loc { get; set; } = default!;
}
