@page "/convention"
@rendermode InteractiveServer
@using System.Globalization
@using Microsoft.Extensions.Localization
@using BlazorNet11.Data
@using BlazorNet11.Resources

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <h1 class="h3 mb-1">@Loc["ConventionTitle"]</h1>
            <p class="text-body-secondary mb-4">@Loc["ConventionSubtitle"]</p>

            <div class="mb-3 d-flex gap-2 small">
                <span>🌐</span>
                <a href="/Culture/Set?culture=en&redirectUri=/contact" data-enhance-nav="false"
                   class="@(CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "en" ? "fw-bold" : "")">English</a>
                <a href="/Culture/Set?culture=es&redirectUri=/contact" data-enhance-nav="false"
                   class="@(CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "es" ? "fw-bold" : "")">Español</a>
            </div>

            <div class="alert alert-info small mb-3">
                <strong>💡 How it works:</strong> @Loc["ConventionExplanation"]
            </div>

            @if (_submitted)
            {
                <div class="alert alert-success">
                    ✅ @Loc["FeedbackSuccess"]
                </div>
                <button class="btn btn-outline-primary btn-sm" @onclick="ResetForm">@Loc["SubmitAnother"]</button>
            }
            else
            {
                <EditForm EditContext="_editContext" OnValidSubmit="HandleValidSubmit">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="mb-3">
                        <label for="Name" class="form-label">@Loc["Your Name"]</label>
                        <InputText @bind-Value="_model.Name" id="Name" class="form-control" />
                        <ValidationMessage For="@(() => _model.Name)" />
                    </div>

                    <div class="mb-3">
                        <label for="Email" class="form-label">@Loc["Email"]</label>
                        <InputText @bind-Value="_model.Email" id="Email" class="form-control" />
                        <ValidationMessage For="@(() => _model.Email)" />
                    </div>

                    <div class="mb-3">
                        <label for="Rating" class="form-label">@Loc["Rating"]</label>
                        <InputNumber @bind-Value="_model.Rating" id="Rating" class="form-control" />
                        <div class="form-text">@Loc["RatingHint"]</div>
                        <ValidationMessage For="@(() => _model.Rating)" />
                    </div>

                    <div class="mb-3">
                        <label for="Comments" class="form-label">@Loc["Comments"]</label>
                        <InputTextArea @bind-Value="_model.Comments" id="Comments" class="form-control" rows="4" />
                        <ValidationMessage For="@(() => _model.Comments)" />
                    </div>

                    <button type="submit" class="btn btn-primary">@Loc["Send"]</button>
                </EditForm>
            }
        </div>
    </div>
</div>

@code {
    [Inject] private IStringLocalizer<LocalizedStrings> Loc { get; set; } = default!;

    private FeedbackModel _model = new();
    private EditContext _editContext = default!;
    private bool _submitted;

    protected override void OnInitialized()
    {
        _editContext = new EditContext(_model);
    }

    private Task HandleValidSubmit()
    {
        _submitted = true;
        return Task.CompletedTask;
    }

    private void ResetForm()
    {
        _model = new();
        _editContext = new EditContext(_model);
        _submitted = false;
    }
}
