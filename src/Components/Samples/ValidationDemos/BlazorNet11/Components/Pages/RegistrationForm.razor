@page "/registration"
@rendermode InteractiveServer
@using System.Globalization
@using Microsoft.Extensions.Localization
@using BlazorNet11.Data
@using BlazorNet11.Resources

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-8">
            <h1 class="h3 mb-1">@Loc["RegistrationTitle"]</h1>
            <p class="text-body-secondary mb-4">@Loc["RegistrationSubtitle"]</p>

            <div class="mb-3 d-flex gap-2 small">
                <span>🌐</span>
                <a href="/Culture/Set?culture=en&redirectUri=/registration" data-enhance-nav="false"
                   class="@(CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "en" ? "fw-bold" : "")">English</a>
                <a href="/Culture/Set?culture=es&redirectUri=/registration" data-enhance-nav="false"
                   class="@(CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "es" ? "fw-bold" : "")">Español</a>
            </div>

            @if (_submitted)
            {
                <div class="alert alert-success">
                    ✅ @Loc["RegistrationSuccess"]
                </div>
                <button class="btn btn-outline-primary btn-sm" @onclick="ResetForm">@Loc["SubmitAnother"]</button>
            }
            else
            {
                <EditForm EditContext="_editContext" OnValidSubmit="HandleValidSubmit">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="mb-3">
                        <label for="Name" class="form-label">@Loc["Full Name"]</label>
                        <InputText @bind-Value="_model.Name" id="Name" class="form-control" />
                        <ValidationMessage For="@(() => _model.Name)" />
                    </div>

                    <div class="mb-3">
                        <label for="Email" class="form-label">@Loc["Email"]</label>
                        <InputText @bind-Value="_model.Email" id="Email" class="form-control" autocomplete="off" />
                        @if (_editContext.IsValidationPending(() => _model.Email))
                        {
                            <div class="text-primary small mt-1">
                                <span class="spinner-border spinner-border-sm" role="status"></span> @Loc["Checking"]
                            </div>
                        }
                        else if (_editContext.IsValidationFaulted(() => _model.Email))
                        {
                            <div class="text-warning small mt-1">
                                ⚠️ @Loc["ValidationFailed"]
                                <button type="button" class="btn btn-link btn-sm p-0"
                                        @onclick="() => RetryValidation(nameof(_model.Email))">@Loc["Retry"]</button>
                            </div>
                        }
                        else if (IsFieldValidAfterAsyncCheck(() => _model.Email))
                        {
                            <div class="text-success small mt-1">✓ Available</div>
                        }
                        else
                        {
                            <ValidationMessage For="@(() => _model.Email)" />
                        }
                    </div>

                    <div class="mb-3">
                        <label for="Username" class="form-label">@Loc["Username"]</label>
                        <InputText @bind-Value="_model.Username" id="Username" class="form-control" autocomplete="off" />
                        @if (_editContext.IsValidationPending(() => _model.Username))
                        {
                            <div class="text-primary small mt-1">
                                <span class="spinner-border spinner-border-sm" role="status"></span> @Loc["Checking"]
                            </div>
                        }
                        else if (_editContext.IsValidationFaulted(() => _model.Username))
                        {
                            <div class="text-warning small mt-1">
                                ⚠️ @Loc["ValidationFailed"]
                                <button type="button" class="btn btn-link btn-sm p-0"
                                        @onclick="() => RetryValidation(nameof(_model.Username))">@Loc["Retry"]</button>
                            </div>
                        }
                        else if (IsFieldValidAfterAsyncCheck(() => _model.Username))
                        {
                            <div class="text-success small mt-1">✓ Available</div>
                        }
                        else
                        {
                            <ValidationMessage For="@(() => _model.Username)" />
                        }
                    </div>

                    <div class="mb-3">
                        <label for="Password" class="form-label">@Loc["Password"]</label>
                        <InputText @bind-Value="_model.Password" id="Password" type="password" class="form-control" autocomplete="new-password" />
                        <ValidationMessage For="@(() => _model.Password)" />
                    </div>

                    <button type="submit" class="btn btn-primary" disabled="@_editContext.IsValidationPending()">
                        @Loc["Register"]
                    </button>
                </EditForm>
            }
        </div>
    </div>
</div>

@code {
    [Inject] private IStringLocalizer<LocalizedStrings> Loc { get; set; } = default!;

    private RegistrationModel _model = new();
    private EditContext _editContext = default!;
    private bool _submitted;

    protected override void OnInitialized()
    {
        _editContext = new EditContext(_model);
        _editContext.SetFieldCssClassProvider(new PendingAwareFieldCssClassProvider());
        _editContext.OnValidationStateChanged += OnValidationStateChanged;
    }

    private void OnValidationStateChanged(object? sender, ValidationStateChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    private Task HandleValidSubmit()
    {
        _submitted = true;
        return Task.CompletedTask;
    }

    private void RetryValidation(string fieldName)
    {
        _editContext.NotifyFieldChanged(_editContext.Field(fieldName));
    }

    private void ResetForm()
    {
        _model = new();
        _editContext = new EditContext(_model);
        _editContext.SetFieldCssClassProvider(new PendingAwareFieldCssClassProvider());
        _editContext.OnValidationStateChanged += OnValidationStateChanged;
        _submitted = false;
    }

    private bool IsFieldValidAfterAsyncCheck<TField>(System.Linq.Expressions.Expression<Func<TField>> accessor)
    {
        var field = FieldIdentifier.Create(accessor);
        return _editContext.IsModified(field)
            && !_editContext.IsValidationPending(field)
            && !_editContext.IsValidationFaulted(field)
            && !_editContext.GetValidationMessages(field).Any();
    }

    private sealed class PendingAwareFieldCssClassProvider : FieldCssClassProvider
    {
        public override string GetFieldCssClass(EditContext editContext, in FieldIdentifier fieldIdentifier)
        {
            if (editContext.IsValidationPending(fieldIdentifier))
            {
                return editContext.IsModified(fieldIdentifier) ? "modified" : "";
            }

            return base.GetFieldCssClass(editContext, fieldIdentifier);
        }
    }
}
