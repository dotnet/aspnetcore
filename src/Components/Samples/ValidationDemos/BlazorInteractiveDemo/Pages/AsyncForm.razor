@page "/async"
@rendermode InteractiveServer
@using System.Globalization
@using BlazorInteractiveDemo.Data
@using Microsoft.Extensions.Localization
@using BlazorInteractiveDemo.Resources

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <h1 class="h3 mb-1">@Loc["AsyncTitle"]</h1>
            <p class="text-body-secondary mb-4">@Loc["AsyncSubtitle"]</p>

            <div class="mb-3 d-flex gap-2 small">
                <span>🌐</span>
                <a href="/async?culture=en" class="@(CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "en" ? "fw-bold" : "")">English</a>
                <a href="/async?culture=es" class="@(CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "es" ? "fw-bold" : "")">Español</a>
            </div>

            <div class="alert alert-info small mb-3">
                <strong>💡 Try it:</strong> @Loc["AsyncHint"]
            </div>

            @if (_submitted)
            {
                <div class="alert alert-success">
                    ✅ @Loc["RegistrationSuccess"]
                </div>
                <button class="btn btn-outline-primary btn-sm" @onclick="ResetForm">@Loc["SubmitAnother"]</button>
            }
            else
            {
                <EditForm EditContext="_editContext" OnValidSubmit="HandleValidSubmit">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="mb-3">
                        <label for="Name" class="form-label">@Loc["Full Name"]</label>
                        <InputText @bind-Value="_model.Name" id="Name" class="form-control" />
                        <ValidationMessage For="@(() => _model.Name)" />
                    </div>

                    <div class="mb-3">
                        <label for="Email" class="form-label">@Loc["Email"]</label>
                        <InputText @bind-Value="_model.Email" id="Email" class="form-control" />
                        @if (_editContext.IsValidationPending(() => _model.Email))
                        {
                            <span class="text-primary small">
                                <span class="spinner-border spinner-border-sm" role="status"></span> @Loc["Checking"]
                            </span>
                        }
                        else if (_editContext.IsValidationFaulted(() => _model.Email))
                        {
                            <span class="text-warning small">
                                ⚠️ @Loc["ValidationFailed"]
                                <button type="button" class="btn btn-link btn-sm p-0" @onclick="() => RetryValidation(nameof(_model.Email))">@Loc["Retry"]</button>
                            </span>
                        }
                        <ValidationMessage For="@(() => _model.Email)" />
                    </div>

                    <div class="mb-3">
                        <label for="Username" class="form-label">@Loc["Username"]</label>
                        <InputText @bind-Value="_model.Username" id="Username" class="form-control" />
                        @if (_editContext.IsValidationPending(() => _model.Username))
                        {
                            <span class="text-primary small">
                                <span class="spinner-border spinner-border-sm" role="status"></span> @Loc["Checking"]
                            </span>
                        }
                        else if (_editContext.IsValidationFaulted(() => _model.Username))
                        {
                            <span class="text-warning small">
                                ⚠️ @Loc["ValidationFailed"]
                                <button type="button" class="btn btn-link btn-sm p-0" @onclick="() => RetryValidation(nameof(_model.Username))">@Loc["Retry"]</button>
                            </span>
                        }
                        <ValidationMessage For="@(() => _model.Username)" />
                    </div>

                    <div class="mb-3">
                        <label for="Password" class="form-label">@Loc["Password"]</label>
                        <InputText @bind-Value="_model.Password" id="Password" type="password" class="form-control" />
                        <ValidationMessage For="@(() => _model.Password)" />
                    </div>

                    <div class="mb-3">
                        <label for="Age" class="form-label">@Loc["Age"]</label>
                        <InputNumber @bind-Value="_model.Age" id="Age" class="form-control" />
                        <ValidationMessage For="@(() => _model.Age)" />
                    </div>

                    <button type="submit" class="btn btn-primary" disabled="@_editContext.IsValidationPending()">
                        @Loc["Register"]
                    </button>
                </EditForm>
            }
        </div>
    </div>
</div>

@code {
    [Inject] private IStringLocalizer<ValidationMessages> Loc { get; set; } = default!;

    private RegistrationModel _model = new();
    private EditContext _editContext = default!;
    private bool _submitted;

    protected override void OnInitialized()
    {
        _editContext = new EditContext(_model);
    }

    private Task HandleValidSubmit()
    {
        _submitted = true;
        return Task.CompletedTask;
    }

    private void RetryValidation(string fieldName)
    {
        _editContext.NotifyFieldChanged(_editContext.Field(fieldName));
    }

    private void ResetForm()
    {
        _model = new();
        _editContext = new EditContext(_model);
        _submitted = false;
    }
}
