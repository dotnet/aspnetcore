@page "/contact-manual"

<PageTitle>Contact (Client Validation)</PageTitle>

<h1>Contact Form — Client-Side Validation Prototype</h1>
<p>This form has manually-added <code>data-val-*</code> attributes for client-side validation.</p>
<p><a href="/contact-manual-extra">Load page with second form</a> — tests enhanced navigation adding a new form to the DOM.</p>
<p><a href="/contact">Compare with server-only form</a></p>

<EditForm Model="Model" OnValidSubmit="HandleValidSubmit" Enhance FormName="contact-manual">
    <DataAnnotationsValidator />

    <div>
        @* Client-side validation summary *@
        <h2>Client-side validation summary</h2>
        <div data-valmsg-summary="true" class="validation-summary-valid">
            <ul></ul>
        </div>
    </div>

    <div>
        @* Server-side validation summary (shows after POST round-trip) *@
        <h2>Server-side validation summary</h2>
        <ValidationSummary />
    </div>

    <div class="form-group">
        <label for="name">Name</label>
        <InputText id="name" @bind-Value="Model.Name"
            data-val="true"
            data-val-required="Name is required."
            data-val-length="Name must be between 2 and 100 characters."
            data-val-length-min="2"
            data-val-length-max="100"
            data-val-noprofanity="Name contains inappropriate language."
            data-val-noprofanity-words="spam,scam,fake" />
        <span data-valmsg-for="Model.Name" class="field-validation-valid"></span>
        <ValidationMessage For="@(() => Model.Name)" />
    </div>

    <div class="form-group">
        <label for="email">Email</label>
        <InputText id="email" @bind-Value="Model.Email"
            data-val="true"
            data-val-required="Email is required."
            data-val-email="Please enter a valid email address." />
        <span data-valmsg-for="Model.Email" class="field-validation-valid"></span>
        <ValidationMessage For="@(() => Model.Email)" />
    </div>

    <div class="form-group">
        <label for="phone">Phone Number</label>
        <InputText id="phone" @bind-Value="Model.PhoneNumber"
            data-val="true"
            data-val-phone="Please enter a valid phone number." />
        <span data-valmsg-for="Model.PhoneNumber" class="field-validation-valid"></span>
        <ValidationMessage For="@(() => Model.PhoneNumber)" />
    </div>

    <div class="form-group">
        <label for="age">Age</label>
        <InputNumber id="age" @bind-Value="Model.Age"
            data-val="true"
            data-val-required="Age is required."
            data-val-range="Age must be between 18 and 120."
            data-val-range-min="18"
            data-val-range-max="120" />
        <span data-valmsg-for="Model.Age" class="field-validation-valid"></span>
        <ValidationMessage For="@(() => Model.Age)" />
    </div>

    <div class="form-group">
        <label for="website">Website</label>
        <InputText id="website" @bind-Value="Model.Website"
            data-val="true"
            data-val-url="Please enter a valid URL." />
        <span data-valmsg-for="Model.Website" class="field-validation-valid"></span>
        <ValidationMessage For="@(() => Model.Website)" />
    </div>

    <div class="form-group">
        <label for="message">Message</label>
        <InputTextArea id="message" @bind-Value="Model.Message"
            data-val="true"
            data-val-required="A message is required."
            data-val-minlength="Message must be at least 10 characters."
            data-val-minlength-min="10"
            data-val-maxlength="Message cannot exceed 1000 characters."
            data-val-maxlength-max="1000"
            data-val-noprofanity="Message contains inappropriate language."
            data-val-noprofanity-words="spam,scam,fake" />
        <span data-valmsg-for="Model.Message" class="field-validation-valid"></span>
        <ValidationMessage For="@(() => Model.Message)" />
    </div>

    <div class="form-group">
        <label for="refcode">Reference Code (XX-0000)</label>
        <InputText id="refcode" @bind-Value="Model.ReferenceCode"
            data-val="true"
            data-val-regex="Reference code must be in the format XX-0000."
            data-val-regex-pattern="^[A-Z]{2}-\d{4}$" />
        <span data-valmsg-for="Model.ReferenceCode" class="field-validation-valid"></span>
        <ValidationMessage For="@(() => Model.ReferenceCode)" />
    </div>

    <div class="form-actions">
        <button type="submit">Submit</button>
        <button type="submit" formnovalidate>Submit without validation</button>
    </div>
</EditForm>

@if (_submitted)
{
    <div class="success-message">
        <h2>Form Submitted Successfully</h2>
        <p>Thank you, @Model.Name! We received your message.</p>
    </div>
}

@code {
    [SupplyParameterFromForm]
    private ContactModel Model { get; set; } = new();

    private bool _submitted;

    private void HandleValidSubmit()
    {
        _submitted = true;
    }
}
