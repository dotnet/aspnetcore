@page "/"
@using System.Globalization
@rendermode InteractiveServer
<PageTitle>Index</PageTitle>

<h3>BindConverter.TryConvertTo&lt;uint&gt; Issue</h3>

<p>
    Expected: returns <code>false</code> for invalid input.<br />
    Actual: throws exception due to underlying <code>TypeConverter</code>.
</p>

@if (!string.IsNullOrEmpty(_output))
{
    <div class="mt-3">
        <strong>Output:</strong>
        <pre>@_output</pre>
    </div>
}

@code {
    string? _output;

    protected override void OnInitialized()
    {
        RunRepro();
    }

    void RunRepro()
    {
        try
        {
            var success = BindConverter.TryConvertTo<uint>(
                "-42",
                CultureInfo.CurrentCulture,
                out _
            );

            _output = $"Expecting False, was: {success}";
        }
        catch (Exception ex)
        {
            _output = $"Unexpected exception:\n{ex}";
        }
    }
}
