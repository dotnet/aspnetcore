@using Microsoft.AspNetCore.Components.Web
@namespace Microsoft.AspNetCore.Components.QuickGrid

<div class="paginator">
    @if (State.TotalItemCount.HasValue)
    {
        <div class="summary">
            @if (SummaryTemplate is not null)
            {
                @SummaryTemplate
            }
            else
            {
                <text>@(Localizer.GetString("QuickGridPaginatorTotalItems", State.TotalItemCount.GetValueOrDefault()))</text>
            }
        </div>
        <nav role="navigation">
            @if (QuickGridFeatureFlags.EnableUrlBasedQuickGridNavigationAndSorting)
            {
                <a class="go-first" href="@(CanGoBack ? GetPageUrl(0) : null)" title="@(Localizer.GetString("QuickGridPaginatorFirstPage"))" aria-label="@(Localizer.GetString("QuickGridPaginatorFirstPage"))" aria-disabled="@(!CanGoBack ? "true" : "false")">«</a>
                <a class="go-previous" href="@(CanGoBack ? GetPageUrl(State.CurrentPageIndex - 1) : null)" title="@(Localizer.GetString("QuickGridPaginatorPreviousPage"))" aria-label="@(Localizer.GetString("QuickGridPaginatorPreviousPage"))" aria-disabled="@(!CanGoBack ? "true" : "false")">‹</a>
                <div class="pagination-text">
                    @Localizer.GetString("QuickGridPaginatorPageSummary", State.CurrentPageIndex + 1, State.LastPageIndex + 1)
                </div>
                <a class="go-next" href="@(CanGoForwards ? GetPageUrl(State.CurrentPageIndex + 1) : null)" title="@(Localizer.GetString("QuickGridPaginatorNextPage"))" aria-label="@(Localizer.GetString("QuickGridPaginatorNextPage"))" aria-disabled="@(!CanGoForwards ? "true" : "false")">›</a>
                <a class="go-last" href="@(CanGoForwards ? GetPageUrl(State.LastPageIndex.GetValueOrDefault(0)) : null)" title="@(Localizer.GetString("QuickGridPaginatorLastPage"))" aria-label="@(Localizer.GetString("QuickGridPaginatorLastPage"))" aria-disabled="@(!CanGoForwards ? "true" : "false")">»</a>
            }
            else
            {
                <button class="go-first" type="button" @onclick="GoFirstAsync" disabled="@(!CanGoBack)" title="@(Localizer.GetString("QuickGridPaginatorFirstPage"))" aria-label="@(Localizer.GetString("QuickGridPaginatorFirstPage"))"></button>
                <button class="go-previous" type="button" @onclick="GoPreviousAsync" disabled="@(!CanGoBack)" title="@(Localizer.GetString("QuickGridPaginatorPreviousPage"))" aria-label="@(Localizer.GetString("QuickGridPaginatorPreviousPage"))"></button>
                <div class="pagination-text">
                    @Localizer.GetString("QuickGridPaginatorPageSummary", State.CurrentPageIndex + 1, State.LastPageIndex + 1)
                </div>
                <button class="go-next" type="button" @onclick="GoNextAsync" disabled="@(!CanGoForwards)" title="@(Localizer.GetString("QuickGridPaginatorNextPage"))" aria-label="@(Localizer.GetString("QuickGridPaginatorNextPage"))"></button>
                <button class="go-last" type="button" @onclick="GoLastAsync" disabled="@(!CanGoForwards)" title="@(Localizer.GetString("QuickGridPaginatorLastPage"))" aria-label="@(Localizer.GetString("QuickGridPaginatorLastPage"))"></button>
            }
        </nav>
    }
</div>
