<Project Sdk="Microsoft.NET.Sdk.StaticWebAssets">

  <PropertyGroup>
    <TargetFramework>$(DefaultNetCoreTargetFramework)</TargetFramework>
    <Description>Build desktop applications with Blazor and a webview.</Description>
    <EmbeddedFilesManifestFileName>Microsoft.Extensions.FileProviders.Embedded.Manifest.xml</EmbeddedFilesManifestFileName>
    <IsShippingPackage>true</IsShippingPackage>
    <DefineConstants>$(DefineConstants);BLAZOR_WEBVIEW</DefineConstants>
    <NoWarn>$(NoWarn);BL0006</NoWarn>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <Nullable>annotations</Nullable>

    <!-- Ship framework assets with BasePath '/' and the '_framework/' prefix in the asset's
         relative path (assets live under wwwroot/_framework/). This matches the convention used by
         Microsoft.AspNetCore.Components.WebAssembly and ensures the '_framework/' segment survives
         materialization into the consuming project (whose BasePath is '/'). -->
    <StaticWebAssetBasePath>/</StaticWebAssetBasePath>
    <!-- SWA Framework Assets: mark all JS files and the fallback blazor.modules.json manifest as
         Framework type during pack. Modeling blazor.modules.json as a framework asset (instead of a
         static web asset group + manifest promotion) avoids a publish-time crash in apps that
         reference an RCL contributing JS modules. See https://github.com/dotnet/aspnetcore/issues/67374. -->
    <StaticWebAssetFrameworkPattern>**/*.js;**/*.modules.json</StaticWebAssetFrameworkPattern>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Microsoft.AspNetCore.Components.WebView.Test" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Update="Resources.resx" ExcludeFromManifest="true" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="$(ComponentsSharedSourceRoot)src\PullFromJSDataStream.cs" LinkBase="Shared" />
    <Compile Include="$(ComponentsSharedSourceRoot)src\TransmitDataStreamToJS.cs" LinkBase="Shared" />
    <Compile Include="$(ComponentsSharedSourceRoot)src\ElementReferenceJsonConverter.cs" LinkBase="Shared" />
    <Compile Include="$(ComponentsSharedSourceRoot)src\JsonSerializerOptionsProvider.cs" LinkBase="Shared" />
    <Compile Include="$(SharedSourceRoot)LinkerFlags.cs" LinkBase="Shared" />
    <Compile Include="$(SharedSourceRoot)StaticWebAssets\**\*.cs" LinkBase="Shared" />
    <Compile Include="$(ComponentsSharedSourceRoot)src\ArrayBuilder.cs" LinkBase="Shared" />
    <Compile Include="$(ComponentsSharedSourceRoot)src\RenderBatchWriter.cs" LinkBase="Shared" />
    <Compile Include="$(ComponentsSharedSourceRoot)src\ArrayBuilderMemoryStream.cs" LinkBase="Shared" />
    <Compile Include="$(ComponentsSharedSourceRoot)src\WebRendererId.cs" LinkBase="Shared" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="Microsoft.AspNetCore.Components.Web" />
    <Reference Include="Microsoft.Extensions.Configuration.Json" />
    <Reference Include="Microsoft.Extensions.Configuration.Binder" />
    <Reference Include="Microsoft.Extensions.FileProviders.Embedded" />
    <Reference Include="Microsoft.Extensions.FileProviders.Composite" />
    <Reference Include="Microsoft.Extensions.Logging" />
  </ItemGroup>

  <!-- This workaround is required when referencing FileProviders.Embedded as a project -->
  <PropertyGroup>
    <_FileProviderTaskAssembly>$(ArtifactsDir)bin\Microsoft.Extensions.FileProviders.Embedded.Manifest.Task\$(Configuration)\netstandard2.0\Microsoft.Extensions.FileProviders.Embedded.Manifest.Task.dll</_FileProviderTaskAssembly>
  </PropertyGroup>

  <UsingTask AssemblyFile="$(_FileProviderTaskAssembly)" TaskName="Microsoft.Extensions.FileProviders.Embedded.Manifest.Task.GenerateEmbeddedResourcesManifest" />

  <PropertyGroup>
    <_BlazorWebViewJSContentRoot Condition="'$(Configuration)' == 'Debug'">$(RepoRoot)src\Components\Web.JS\dist\Debug</_BlazorWebViewJSContentRoot>
    <_BlazorWebViewJSContentRoot Condition="'$(Configuration)' == 'Release'">$(RepoRoot)src\Components\Web.JS\dist\Release</_BlazorWebViewJSContentRoot>
  </PropertyGroup>

  <!-- Include blazor.webview.js as Content under wwwroot/_framework/ so the SWA pipeline discovers
       it as a framework asset (BasePath '/'). ContentRoot points to the JS dist folder so the
       runtime middleware can serve files directly. -->
  <ItemGroup Condition="'$(BuildNodeJS)' != 'false'">
    <Content Include="$(_BlazorWebViewJSContentRoot)\blazor.webview.js" Link="wwwroot\_framework\blazor.webview.js" ContentRoot="$(_BlazorWebViewJSContentRoot)\" />
  </ItemGroup>

  <!-- blazor.modules.json (under wwwroot/_framework/) is a fallback manifest for WebView apps that
       don't contribute JS library modules. It is modeled as a framework static web asset (matched by
       StaticWebAssetFrameworkPattern). The JSModule trait lets the SDK treat it as the JS module
       manifest so the app's own generated manifest, when present, supersedes it. -->
  <ItemGroup>
    <Content Update="wwwroot\_framework\blazor.modules.json"
      AssetTraitName="JSModule" AssetTraitValue="JSModuleManifest" />
  </ItemGroup>

  <!-- blazor.webview.js should exist after eng/Npm.Workspace.nodeproj builds. Warn if not. -->
  <Target Name="_CheckBlazorWebViewJSPath" AfterTargets="ResolveProjectReferences" Condition="'$(BuildNodeJS)' != 'false' and !EXISTS('$(_BlazorWebViewJSContentRoot)\blazor.webview.js')">
    <Warning Text="'$(_BlazorWebViewJSContentRoot)\blazor.webview.js' does not exist and won't be included in the build." />
  </Target>

</Project>
