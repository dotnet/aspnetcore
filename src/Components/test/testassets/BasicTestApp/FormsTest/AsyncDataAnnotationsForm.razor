@using Microsoft.AspNetCore.Components.Forms
@implements IDisposable

@* Shared markup for the DataAnnotations async validation E2E components. The concrete model (passed by
   a thin wrapper component) determines whether validation runs through the static Validator path or the
   Microsoft.Extensions.Validation (MEV) path. A custom EditContext is used so the component can subscribe
   to OnValidationStateChanged and re-render its own faulted-state markup as async validation settles. *@

<EditForm EditContext="_editContext" OnValidSubmit="HandleValidSubmit" OnInvalidSubmit="HandleInvalidSubmit">
    <DataAnnotationsValidator />

    <p class="user-name">
        User name: <InputText @bind-Value="Model.Username" />
    </p>

    @if (_editContext.IsValidationFaulted(() => Model.Username))
    {
        <span id="username-faulted">@_editContext.GetValidationException(() => Model.Username)?.Message</span>
    }

    <button type="submit" id="submit">Submit</button>

    <ul class="validation-errors">
        @foreach (var message in _editContext.GetValidationMessages())
        {
            <li class="validation-message">@message</li>
        }
    </ul>
</EditForm>

@if (_lastCallback != null)
{
    <span id="last-callback">@_lastCallback</span>
}

@code {
    [Parameter] public AsyncRegistrationModelBase Model { get; set; }

    private EditContext _editContext;
    private string _lastCallback;

    protected override void OnInitialized()
    {
        _editContext = new EditContext(Model);
        _editContext.OnValidationStateChanged += OnValidationStateChanged;
    }

    private void OnValidationStateChanged(object sender, ValidationStateChangedEventArgs e)
        => InvokeAsync(StateHasChanged);

    private void HandleValidSubmit() => _lastCallback = "OnValidSubmit";

    private void HandleInvalidSubmit() => _lastCallback = "OnInvalidSubmit";

    public void Dispose()
        => _editContext.OnValidationStateChanged -= OnValidationStateChanged;
}
