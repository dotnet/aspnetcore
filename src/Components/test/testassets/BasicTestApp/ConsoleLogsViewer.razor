@using Microsoft.AspNetCore.Components.Web.Virtualization
@using System.Threading
@implements IAsyncDisposable

<h1 id="console-logs-viewer-heading">Console Logs Viewer (Virtualize AnchorMode.End)</h1>

<p>
    Total lines streamed: <span id="console-total-count">@_entries.Count</span>
    &nbsp;Streaming: <span id="console-streaming-state">@(_streaming ? "on" : "off")</span>
    <button id="console-start-stream" @onclick="StartStreamingAsync">Start streaming</button>
    <button id="console-stop-stream" @onclick="StopStreaming">Stop streaming</button>
    <button id="console-reset-stream" @onclick="ResetAsync">Reset</button>
</p>

<div class="log-overflow console-overflow continuous-scroll-overflow"
     id="console-scroll-container"
     data-theme="dark"
     style="height: 585px; overflow-y: auto; border: 1px solid #444; background: #1e1e1e; color: #dddddd; font-family: Consolas, monospace; font-size: 13px;">
    <div class="log-container console-container" id="logContainer">
        <Virtualize @ref="_virtualizeRef"
                    ItemsProvider="GetItemsAsync"
                    ItemComparer="@(EqualityComparer<LogLine>.Default)"
                    ItemSize="20"
                    OverscanCount="200"
                    TItem="LogLine"
                    AnchorMode="VirtualizeAnchorMode.End"
                    Context="line">
            <div class="log-line-row console-line-row" data-line="@line.LineNumber" style="height: 20px; line-height: 20px; white-space: nowrap;">
                <span class="log-line-number" style="display: inline-block; width: 56px; color: #888; text-align: right; padding-right: 8px; user-select: none;">@line.LineNumber</span>
                <span class="log-content">@line.Content</span>
            </div>
        </Virtualize>
    </div>
</div>

@code {
    private readonly List<LogLine> _entries = new();
    private Virtualize<LogLine> _virtualizeRef;
    private CancellationTokenSource _streamCts;
    private bool _streaming;
    private bool _autoStarted;
    private int _nextLineNumber = 1;

    // Mirrors how a real console behaves: a chunk of existing history is shown first, then new lines are tailed
    // slowly, roughly one append per second. The slow cadence makes the bug easy to observe manually.
    private const int InitialSeedLines = 80;
    private const int BatchSize = 2;
    private const int BatchIntervalMs = 1000;
    private const int TotalLinesToStream = 600;

    protected override void OnInitialized()
    {
        for (var i = 0; i < InitialSeedLines; i++)
        {
            var n = _nextLineNumber++;
            _entries.Add(new LogLine(n, $"{n} Out  log line content for line {n}"));
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_autoStarted)
        {
            _autoStarted = true;
            await StartStreamingAsync();
        }
    }

    private async Task StartStreamingAsync()
    {
        if (_streaming)
        {
            return;
        }

        _streaming = true;
        _streamCts = new CancellationTokenSource();
        var token = _streamCts.Token;
        _ = StreamLoopAsync(token);
        await Task.CompletedTask;
    }

    private async Task StreamLoopAsync(CancellationToken token)
    {
        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromMilliseconds(BatchIntervalMs));
            while (!token.IsCancellationRequested
                && _entries.Count < TotalLinesToStream
                && await timer.WaitForNextTickAsync(token))
            {
                for (var i = 0; i < BatchSize && _entries.Count < TotalLinesToStream; i++)
                {
                    var n = _nextLineNumber++;
                    _entries.Add(new LogLine(n, $"{n} Out  log line content for line {n}"));
                }

                await InvokeAsync(async () =>
                {
                    if (_virtualizeRef is not null)
                    {
                        await _virtualizeRef.RefreshDataAsync();
                    }

                    StateHasChanged();
                });
            }
        }
        catch (OperationCanceledException)
        {
        }
        finally
        {
            _streaming = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void StopStreaming()
    {
        _streamCts?.Cancel();
        _streaming = false;
    }

    private async Task ResetAsync()
    {
        StopStreaming();
        _entries.Clear();
        _nextLineNumber = 1;
        for (var i = 0; i < InitialSeedLines; i++)
        {
            var n = _nextLineNumber++;
            _entries.Add(new LogLine(n, $"{n} Out  log line content for line {n}"));
        }

        if (_virtualizeRef is not null)
        {
            await _virtualizeRef.RefreshDataAsync();
        }

        StateHasChanged();
    }

    private ValueTask<ItemsProviderResult<LogLine>> GetItemsAsync(ItemsProviderRequest request)
    {
        var slice = _entries.Skip(request.StartIndex).Take(request.Count);
        return ValueTask.FromResult(new ItemsProviderResult<LogLine>(slice, _entries.Count));
    }

    public async ValueTask DisposeAsync()
    {
        _streamCts?.Cancel();
        _streamCts?.Dispose();
        await ValueTask.CompletedTask;
    }

    private sealed record LogLine(int LineNumber, string Content);
}
