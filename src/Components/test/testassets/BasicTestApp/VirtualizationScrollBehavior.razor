@* Tests: rapid scroll reversals, programmatic scrollToBottom, non-zero start index *@
<p>
    <b>Rapid Scroll & ScrollToBottom Test</b>:<br />
    <span id="scroll-item-count">@items.Count</span>
    <div id="scroll-behavior-container" style="background-color: #eee; height: 200px; overflow-y: auto">
        <Virtualize Items="@items" ItemSize="35">
            <div @key="context.Index" id="scroll-item-@context.Index" class="scroll-behavior-item"
                 style="height: @(context.Height)px; background-color: hsl(@(context.Hue), 70%, 80%); padding: 4px; box-sizing: border-box;">
                <span class="item-index">@context.Index</span>
            </div>
        </Virtualize>
    </div>
</p>

@code {
    ICollection<HeightItem> items;

    protected override void OnInitialized()
    {
        items = Enumerable.Range(0, 500).Select(i => new HeightItem
        {
            Index = i,
            Height = 25 + (i * 11 % 31),
            Hue = i * 7 % 360
        }).ToList();
    }

    class HeightItem
    {
        public int Index { get; set; }
        public int Height { get; set; }
        public int Hue { get; set; }
    }
}
