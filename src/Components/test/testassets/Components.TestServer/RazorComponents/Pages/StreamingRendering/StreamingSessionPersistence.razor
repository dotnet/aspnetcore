@page "/streaming-session-persistence"
@attribute [StreamRendering]

<h1>Streaming Session Persistence Test</h1>

@if (_done)
{
    <p id="streaming-complete">Done</p>
    <p id="session-value">@StreamingSessionPersistenceValue</p>
    <p id="tempdata-value">@SupplyFromTempDataValue</p>
    <p id="tempdata-message">@_tempDataMessage</p>
}
else
{
    <p id="streaming-status">Waiting for streaming...</p>
}

@code {
    private bool _done;
    private string? _tempDataMessage;

    [SupplyParameterFromSession(Name = "StreamingSessionPersistenceValue")]
    public string? StreamingSessionPersistenceValue { get; set; }

    [SupplyParameterFromTempData]
    private string SupplyFromTempDataValue { get; set; } = string.Empty;

    [CascadingParameter]
    public ITempData? TempData { get; set; }

    protected override async Task OnInitializedAsync()
    {
        // The await is critical: it causes the component to enter the streaming phase.
        // Values set AFTER the await are the ones that were silently lost with the old
        // OnStarting-based persistence, because OnStarting fires before streaming begins.
        await Task.Delay(100);

        StreamingSessionPersistenceValue = "set-during-streaming";
        SupplyFromTempDataValue = "tempdata-set-during-streaming";
        if (TempData is not null)
        {
            TempData["StreamingTempDataMessage"] = "streaming-tempdata-message";
            _tempDataMessage = "tempdata-was-set";
        }
        else
        {
            _tempDataMessage = "tempdata-was-null";
        }
        _done = true;
    }
}
