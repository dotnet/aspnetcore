@page "/persistent-state/auto-pause-serviceworker"
@rendermode RenderMode.InteractiveServer

<h1>Auto-pause — Service Worker survives pause</h1>
<script src="/subdir/auto-pause-log-capture.js"></script>

@if (RendererInfo.IsInteractive)
{
    <span id="render-mode-interactive">True</span>
}

<button id="start-sw" data-token="@_token" onclick="window.startGatedServiceWorker('@_token')">Start SW event</button>

<script>
    window.__swResult = window.__swResult || 'idle';

    navigator.serviceWorker.register('/subdir/autopause-test-sw.js', { scope: '/subdir/persistent-state/' })
        .then(function () { return navigator.serviceWorker.ready; })
        .then(function () { window.__swReady = true; });

    navigator.serviceWorker.addEventListener('message', function (e) {
        if (e.data && e.data.type === 'result') { window.__swResult = e.data.value; }
    });

    window.startGatedServiceWorker = function (token) {
        window.__swResult = 'pending';
        navigator.serviceWorker.ready.then(function (reg) {
            reg.active.postMessage({ type: 'start', token: token });
        });
    };
</script>

@code {
    private readonly string _token = Guid.NewGuid().ToString("N");
}
