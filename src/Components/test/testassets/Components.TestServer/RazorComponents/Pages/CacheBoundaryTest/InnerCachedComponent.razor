<p id="inner-cached">@Guid.NewGuid()</p>

@code
{
    private static readonly Dictionary<string, int> _renderCounts = new();

    // The testId of the request that rendered this component, so each E2E test observes only its own
    // render count and the counter is not polluted by other tests loading the same page.
    [Parameter] public string? TestId { get; set; }

    public static int GetRenderCount(string testId)
        => _renderCounts.TryGetValue(testId, out var count) ? count : 0;

    public static void ResetRenderCount() => _renderCounts.Clear();

    protected override void OnInitialized()
    {
        var key = TestId ?? "";
        _renderCounts[key] = GetRenderCount(key) + 1;
    }
}
