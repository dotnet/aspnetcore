@* A reusable component that internally contains a CacheBoundary with no explicit CacheKey.
   Using it more than once on a page produces two CacheBoundary instances that resolve to the
   same cache key (same parent type + sequence), with no user error. This must not hang the
   request. *@

<div class="reusable-panel">
    <CacheBoundary ExpiresAfter="TimeSpan.FromHours(1)" VaryByQuery="testId">
        <p class="panel-content">@Label</p>
        <p class="panel-guid">@Guid.NewGuid()</p>
    </CacheBoundary>
</div>

@code {
    [Parameter]
    public string Label { get; set; } = "";
}
