@page "/cache-component"
@page "/cache-component/vary"
@using Microsoft.AspNetCore.Components.Forms

<h3>CacheBoundary</h3>

<div id="test-1">
    <CacheBoundary ExpiresAfter="TimeSpan.FromHours(1)">
        <p class="cached">@Guid.NewGuid()</p>
        <ExcludedContent>
            <p class="not-cache-component">@Guid.NewGuid()</p>
        </ExcludedContent>
    </CacheBoundary>
    <p class="not-cached">@Guid.NewGuid()</p>
</div>

<div id="test-2">
    <CacheBoundary ExpiresAfter="TimeSpan.FromHours(1)" Enabled="false">
        <p class="cached">@Guid.NewGuid()</p>
        <ExcludedContent>
            <p class="not-cache-component">@Guid.NewGuid()</p>
        </ExcludedContent>
    </CacheBoundary>
    <p class="not-cached">@Guid.NewGuid()</p>
</div>

<div id="test-3">
    <EditForm Model="this" FormName="editFormTest" method="post">
        <CacheBoundary ExpiresAfter="TimeSpan.FromHours(1)">
            <input id="message-input" type="text" name="Message" />
            <button id="submit" type="submit">Submit</button>
        </CacheBoundary>
        <ExcludedContent>
            <p id="message">@Message</p>
        </ExcludedContent>
    </EditForm>
</div>

<div id="test-4">
    <CacheBoundary ExpiresAfter="TimeSpan.FromHours(1)">
        <p id="outer-cached">@Guid.NewGuid()</p>
        <CacheBoundary ExpiresAfter="TimeSpan.FromHours(1)">
            <InnerCachedComponent />
        </CacheBoundary>
    </CacheBoundary>
</div>

<div id="test-5">
    @for (var i = 0; i < 3; i++)
    {
        <div class="loop-item" data-index="@i">
            <CacheBoundary ExpiresAfter="TimeSpan.FromHours(1)" CacheKey="@($"loop-{i}")">
                <p class="cached-value">@Guid.NewGuid()</p>
            </CacheBoundary>
        </div>
    }
</div>

<div id="test-8">
    <CacheBoundary ExpiresAfter="TimeSpan.FromHours(1)">
        <p class="cached-content">@Guid.NewGuid()</p>
        @for (var i = 0; i < 2; i++)
        {
            var index = i;
            var label = index == 0 ? "first" : "second";
            <ExcludedContent>
                <p class="hole-@index">@label</p>
            </ExcludedContent>
        }
    </CacheBoundary>
</div>

@code
{
    [SupplyParameterFromForm(FormName = "editFormTest")]
    private string Message { get; set; } = "never";
}
