@page "/cache-component"
@page "/cache-component/vary"
@using Microsoft.AspNetCore.Components.Forms

<h3>CacheBoundary</h3>

<div id="test-1">
    <CacheBoundary ExpiresAfter="TimeSpan.FromHours(1)" VaryByQuery="testId">
        <p class="cached">@Guid.NewGuid()</p>
        <HoleComponent CssClass="not-cache-component" />
    </CacheBoundary>
    <p class="not-cached">@Guid.NewGuid()</p>
</div>

<div id="test-2">
    <CacheBoundary ExpiresAfter="TimeSpan.FromHours(1)" VaryByQuery="testId" Enabled="false">
        <p class="cached">@Guid.NewGuid()</p>
        <HoleComponent CssClass="not-cache-component" />
    </CacheBoundary>
    <p class="not-cached">@Guid.NewGuid()</p>
</div>

<div id="test-3">
    <EditForm Model="this" FormName="editFormTest" method="post">
        <CacheBoundary ExpiresAfter="TimeSpan.FromHours(1)" VaryByQuery="testId">
            <input id="message-input" type="text" name="Message" />
            <button id="submit" type="submit">Submit</button>
        </CacheBoundary>
        <HoleComponent Id="message" Content="@Message" />
    </EditForm>
</div>

<div id="test-4">
    @for (var i = 0; i < 3; i++)
    {
        <div class="loop-item" data-index="@i">
            <CacheBoundary ExpiresAfter="TimeSpan.FromHours(1)" VaryByQuery="testId" CacheKey="@($"loop-{i}")">
                <p class="cached-value">@Guid.NewGuid()</p>
            </CacheBoundary>
        </div>
    }
</div>

<div id="test-5">
    <CacheBoundary ExpiresAfter="TimeSpan.FromHours(1)" VaryByQuery="testId">
        <p class="cached-content">@Guid.NewGuid()</p>
        @for (var i = 0; i < 2; i++)
        {
            var index = i;
            var label = index == 0 ? "first" : "second";
            <HoleComponent CssClass="@($"hole-{index}")" Content="@label" />
        }
    </CacheBoundary>
</div>

<div id="test-7">
    <CacheBoundary ExpiresAfter="TimeSpan.FromHours(1)" VaryByQuery="testId">
        <HardcodedHolePanel />
    </CacheBoundary>
</div>

<div id="test-8">
    <CacheBoundary ExpiresAfter="TimeSpan.FromHours(1)" VaryByQuery="testId">
        <p class="cached-static">@Guid.NewGuid()</p>
        <StreamingHoleComponent CssClass="streaming-hole" />
    </CacheBoundary>
</div>

@code
{
    [SupplyParameterFromForm(FormName = "editFormTest")]
    private string Message { get; set; } = "never";
}
