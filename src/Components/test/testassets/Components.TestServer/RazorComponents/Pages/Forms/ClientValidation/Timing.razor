@page "/forms/client-validation/timing"

<h2 id="page-title">Validation triggers</h2>

<style>
    .field-validation-error { color: red; }
    .field-validation-valid { display: none; }
</style>

<form id="test-form" method="post">
    @* Default: change + gated input *@
    <input id="default-field" name="Default" type="text"
           data-val="true"
           data-val-required="Default is required." />
    <span data-valmsg-for="Default" data-valmsg-replace="true"></span>

    @* data-valevent="submit": only validated on form submit *@
    <input id="submit-only" name="SubmitOnly" type="text"
           data-val="true"
           data-val-required="SubmitOnly is required."
           data-valevent="submit" />
    <span data-valmsg-for="SubmitOnly" data-valmsg-replace="true"></span>

    @* data-valevent="change": only validated on change/blur, never on input *@
    <input id="change-only" name="ChangeOnly" type="text"
           data-val="true"
           data-val-required="ChangeOnly is required."
           data-valevent="change" />
    <span data-valmsg-for="ChangeOnly" data-valmsg-replace="true"></span>

    @* data-valevent="input": always validated on every keystroke *@
    <input id="input-eager" name="InputEager" type="text"
           data-val="true"
           data-val-required="InputEager is required."
           data-valevent="input" />
    <span data-valmsg-for="InputEager" data-valmsg-replace="true"></span>

    <button type="submit" id="submit">Submit</button>
    <button type="reset" id="reset">Reset</button>
</form>
