@page "/forms/client-validation/basic-validation"

<h2 id="page-title">Basic client-side validation</h2>

<style>
    .input-validation-error { border-color: red; }
    .input-validation-valid { border-color: green; }
    .field-validation-error { color: red; display: block; }
    .field-validation-valid { display: none; }
    .validation-summary-errors { color: red; }
    .validation-summary-valid { display: none; }
</style>

<form id="test-form" method="post">
    <div data-valmsg-summary="true" class="validation-summary-valid">
        <ul></ul>
    </div>

    <div>
        <label for="name">Name (required)</label>
        <input id="name" name="Name" type="text"
               data-val="true"
               data-val-required="The Name field is required." />
        <span data-valmsg-for="Name" data-valmsg-replace="true"></span>
    </div>

    <div>
        <label for="email">Email (required)</label>
        <input id="email" name="Email" type="text"
               data-val="true"
               data-val-required="The Email field is required." />
        <span data-valmsg-for="Email" data-valmsg-replace="true"></span>
    </div>

    <div>
        <label for="bio">Bio (maxlength 100)</label>
        <textarea id="bio" name="Bio"
                  data-val="true"
                  data-val-maxlength="Bio must be at most 100 characters."
                  data-val-maxlength-max="100"></textarea>
        <span data-valmsg-for="Bio" data-valmsg-replace="true"></span>
    </div>

    <div>
        <label for="password">Password (length 8-50)</label>
        <input id="password" name="Password" type="password"
               data-val="true"
               data-val-required="Password is required."
               data-val-length="Password must be between 8 and 50 characters."
               data-val-length-min="8"
               data-val-length-max="50" />
        <span data-valmsg-for="Password" data-valmsg-replace="true"></span>
    </div>

    <div>
        <label>
            <input id="agree" name="Agree" type="checkbox"
                   data-val="true"
                   data-val-required="You must agree to the terms." />
            I agree to the terms
        </label>
        <span data-valmsg-for="Agree" data-valmsg-replace="true"></span>
    </div>

    <div>
        <label for="category">Category (required select)</label>
        <select id="category" name="Category"
                data-val="true"
                data-val-required="Please select a category.">
            <option value="">-- Select --</option>
            <option value="A">Category A</option>
            <option value="B">Category B</option>
        </select>
        <span data-valmsg-for="Category" data-valmsg-replace="true"></span>
    </div>

    <button type="submit" id="submit">Submit</button>
    <button type="reset" id="reset">Reset</button>
</form>

<div id="event-log"></div>

<script suppress-error="BL9992">
    document.getElementById('test-form').addEventListener('validationcomplete', function (e) {
        var payload = 'valid:' + e.detail.valid + ';errors:' + e.detail.errors.size;
        document.getElementById('event-log').textContent = payload;
        // localStorage survives form-post page reloads so tests can read the
        // event detail even if validation passed and the form was submitted.
        localStorage.setItem('lastValidation', payload);
    });
</script>
