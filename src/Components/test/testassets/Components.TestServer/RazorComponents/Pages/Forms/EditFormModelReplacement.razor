@page "/forms/editform-model-replacement"
@using Microsoft.AspNetCore.Components.Forms

<h2 id="page-title">EditForm model replacement</h2>

<p id="outside-lifecycle">outside: @string.Join(", ", _outsideEvents)</p>
<p id="inside-lifecycle">inside: @string.Join(", ", _insideEvents)</p>

<EditForm Model="@_model" OnSubmit="@(_ => { })">
    <LifecycleReporter Id="inside-reporter" OnLifecycleEvent="@(e => _insideEvents.Add(e))" />
</EditForm>

<LifecycleReporter Id="outside-reporter" OnLifecycleEvent="@(e => _outsideEvents.Add(e))" />

<button id="replace-model" @onclick="ReplaceModel">Replace model</button>
<p id="swap-count">Swaps: @_swapCount</p>

@code {
    private FormModel _model = new();
    private int _swapCount;
    private readonly List<string> _insideEvents = new();
    private readonly List<string> _outsideEvents = new();

    private void ReplaceModel()
    {
        _model = new FormModel();
        _swapCount++;
    }

    private sealed class FormModel
    {
        public string Name { get; set; } = string.Empty;
    }

    private sealed class LifecycleReporter : ComponentBase, IDisposable
    {
        [Parameter, EditorRequired] public string Id { get; set; } = string.Empty;
        [Parameter] public Action<string>? OnLifecycleEvent { get; set; }

        protected override void BuildRenderTree(Microsoft.AspNetCore.Components.Rendering.RenderTreeBuilder builder)
        {
            builder.OpenElement(0, "span");
            builder.AddAttribute(1, "id", Id);
            builder.AddContent(2, Id);
            builder.CloseElement();
        }

        protected override void OnInitialized()
        {
            OnLifecycleEvent?.Invoke("init");
            base.OnInitialized();
        }

        protected override void OnParametersSet()
        {
            OnLifecycleEvent?.Invoke("params");
            base.OnParametersSet();
        }

        public void Dispose()
        {
            OnLifecycleEvent?.Invoke("dispose");
        }
    }
}
