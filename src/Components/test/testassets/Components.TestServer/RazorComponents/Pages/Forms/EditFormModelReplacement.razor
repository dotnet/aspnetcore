@page "/forms/editform-model-replacement"
@rendermode RenderMode.InteractiveServer
@using Microsoft.AspNetCore.Components.Forms
@using Components.TestServer.RazorComponents.Shared

<h2 id="page-title">EditForm model replacement</h2>

<p id="is-interactive">@RendererInfo.IsInteractive</p>

<div>
    <EditForm Model="@_allowModelChangeModel" AllowModelChange="true" OnSubmit="@(_ => { })">
        <LifecycleReporter Id="allow-model-change-reporter" OnLifecycleEvent="AppendAllowModelChangeLog" />
        <div>
            <label>Name: <InputText id="allow-model-change-name-input" @bind-Value="_allowModelChangeModel.Name" /></label>
        </div>
    </EditForm>

    <button id="replace-allow-model-change-model" @onclick="ReplaceAllowModelChangeModel">Replace model (AllowModelChange=true)</button>
    <p id="allow-model-change-swap-count">Swaps: @_allowModelChangeSwapCount</p>
    <ul id="allow-model-change-log">
        @foreach (var entry in _allowModelChangeLog) { <li>@entry</li> }
    </ul>
</div>

@code {
    private FormModel _allowModelChangeModel = new();
    private int _allowModelChangeSwapCount;
    private readonly List<string> _allowModelChangeLog = [];

    private void ReplaceAllowModelChangeModel()
    {
        _allowModelChangeModel = new FormModel { Name = $"New model #{++_allowModelChangeSwapCount}" };
        _allowModelChangeLog.Add($"── swap #{_allowModelChangeSwapCount} ──");
    }

    private void AppendAllowModelChangeLog(string msg) => _allowModelChangeLog.Add(msg);

    // ── Model types ──────────────────────────────────────────────────────────
    private sealed class FormModel
    {
        public string Name { get; set; } = string.Empty;
    }
}
