@using Microsoft.AspNetCore.Components.QuickGrid

@attribute [Microsoft.AspNetCore.Components.RouteAttribute("/quickgrid-advanced")]

<h3>QuickGrid Advanced Test Component</h3>

<p id="default-sort-state">@defaultSortState</p>
<p id="custom-sort-state">@customSortState</p>
<p id="items-provider-calls">@itemsProviderCalls</p>

<div id="default-sort-grid">
    <QuickGrid Items="@defaultSortPeople" Pagination="@defaultSortPagination">
        <PropertyColumn Property="@(p => p.Id)" Sortable="true" IsDefaultSortColumn="true" InitialSortDirection="SortDirection.Descending" />
        <PropertyColumn Property="@(p => p.Name)" Sortable="true" />
    </QuickGrid>
</div>

<div id="custom-sort-grid">
    <QuickGrid ItemsProvider="@customSortProvider" Pagination="@customSortPagination" @ref="customSortGrid">
        <TemplateColumn Title="Location" SortBy="@locationSort">
            <div>@context.City, @context.Country</div>
        </TemplateColumn>
        <PropertyColumn Property="@(p => p.Population)" Sortable="true" />
    </QuickGrid>
</div>

<div id="item-key-grid">
    <QuickGrid Items="@itemKeyPeople" ItemKey="@(p => p.Id)">
        <PropertyColumn Property="@(p => p.Id)" Title="Id" />
        <PropertyColumn Property="@(p => p.Name)" Title="Name" />
    </QuickGrid>
</div>

<button id="replace-item-key-data" @onclick="ReplaceItemKeyData">Replace item key data</button>
<p id="item-key-state">@itemKeyState</p>

@code {
    private record DefaultSortItem(int Id, string Name);
    private record LocationItem(string City, string Country, int Population);
    private record KeyItem(int Id, string Name);

    private PaginationState defaultSortPagination = new() { ItemsPerPage = 2 };
    private PaginationState customSortPagination = new() { ItemsPerPage = 2 };
    private QuickGrid<LocationItem> customSortGrid = default!;

    private IQueryable<KeyItem> itemKeyPeople = new[]
    {
        new KeyItem(1, "Alpha"),
        new KeyItem(2, "Bravo"),
    }.AsQueryable();

    private string defaultSortState = string.Empty;
    private string customSortState = string.Empty;
    private string itemKeyState = "initial";
    private int itemsProviderCalls;

    private readonly IQueryable<DefaultSortItem> defaultSortPeople = new[]
    {
        new DefaultSortItem(1, "Alpha"),
        new DefaultSortItem(3, "Charlie"),
        new DefaultSortItem(2, "Bravo"),
    }.AsQueryable();

    private readonly IQueryable<LocationItem> locations = new[]
    {
        new LocationItem("Tokyo", "Japan", 37),
        new LocationItem("Osaka", "Japan", 19),
        new LocationItem("Delhi", "India", 32),
        new LocationItem("Mumbai", "India", 20),
    }.AsQueryable();

    private GridSort<LocationItem> locationSort = GridSort<LocationItem>.ByAscending(x => x.Country).ThenAscending(x => x.City);

    protected override void OnInitialized()
    {
        customSortProvider = request =>
        {
            itemsProviderCalls++;
            var query = request.ApplySorting(locations).AsQueryable();
            customSortState = string.Join("|", request.GetSortByProperties().Select(p => $"{p.PropertyName}:{p.Direction}"));
            var items = query.Skip(request.StartIndex).Take(request.Count ?? 2).ToList();
            StateHasChanged();
            return ValueTask.FromResult(GridItemsProviderResult.From(items, query.Count()));
        };
    }

    private GridItemsProvider<LocationItem> customSortProvider = default!;

    private void ReplaceItemKeyData()
    {
        itemKeyPeople = new[]
        {
            new KeyItem(1, "Alpha updated"),
            new KeyItem(2, "Bravo updated"),
        }.AsQueryable();
        itemKeyState = "replaced";
    }

    protected override void OnAfterRender(bool firstRender)
    {
        defaultSortState = $"{defaultSortPagination.CurrentPageIndex}:{defaultSortPagination.TotalItemCount}:{defaultSortPagination.LastPageIndex}";
        base.OnAfterRender(firstRender);
    }
}
