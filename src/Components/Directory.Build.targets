<Project>
  <!-- blazor.webassembly.js is now provided as a framework static web asset from
       Microsoft.AspNetCore.App.Internal.Assets. No need to set BlazorWebAssemblyJSPath
       for the Wasm SDK to resolve it separately. -->

  <Import Project="$([MSBuild]::GetDirectoryNameOfFileAbove($(MSBuildThisFileDirectory)..\, Directory.Build.targets))\Directory.Build.targets" />
</Project>
