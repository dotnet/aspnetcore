@page "/"
@inject IStringLocalizerFactory LocalizerFactory

@{
    var localizer = LocalizerFactory.Create("Validation", "BlazorServerDemo");
}

<PageTitle>@localizer["HomeTitle"]</PageTitle>

<section class="hero">
    <div class="badge">Async + Localized</div>
    <h2>@localizer["HomeTitle"]</h2>
    <p>@localizer["HomeDescription"]</p>
    <a href="/register" class="btn">@localizer["GoToRegister"]</a>
</section>
