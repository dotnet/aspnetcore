@{
    ViewData["Title"] = "Home";
}

<section class="hero">
    <h2>Welcome</h2>
    <p>
        This demo shows that <strong>aspnet-validation.js</strong> is a drop-in replacement
        for jQuery Validation Unobtrusive in ASP.NET Core MVC apps.
    </p>
    <p>
        No jQuery, no additional dependencies &mdash; just a single lightweight script
        that reads the same <code>data-val-*</code> attributes emitted by MVC tag helpers.
    </p>
    <a asp-controller="Home" asp-action="Contact" class="btn">Try the Contact Form &rarr;</a>
</section>
